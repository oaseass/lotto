generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 유저
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?   // 소셜 로그인시 null
  nickname     String
  gender       String?   // M / F / N
  isAdFree     Boolean   @default(false)
  isAdmin      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // 관계
  sajuProfile    SajuProfile?
  lottoNumbers   LottoNumber[]
  qrScans        QrScan[]
  adFreePurchase AdFreePurchase?
  accounts       Account[]
  sessions       Session[]
  pushTokens     PushToken[]
}

// NextAuth 계정 (소셜 로그인용)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// 사주 프로필 (유저당 1개)
model SajuProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  // 입력값 (원본)
  birthYear    Int
  birthMonth   Int
  birthDay     Int
  birthHour    Float?   // 0~23.5 (0.5 단위 = 30분), 모를 경우 null
  isLunar      Boolean  @default(false)
  isLeapMonth  Boolean  @default(false) // 윤달 여부
  // 변환된 양력 날짜 (사주 계산 기준)
  solarYear    Int?
  solarMonth   Int?
  solarDay     Int?
  // 사주 계산 결과
  cheonjigan   Json?    // 천간지지 4주8자 계산 결과
  ohaeng       Json?    // 오행 비율 {목:2, 화:1, ...}
  ilju         String?  // 일주 (예: 갑자)
  yongsin      String?  // 용신 오행
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 생성된 로또 번호
model LottoNumber {
  id            String   @id @default(cuid())
  userId        String
  generatedDate DateTime // 어떤 날짜 기준으로 생성했는지
  numbers       Int[]    // [3, 12, 24, 33, 38, 45]
  reason        String?  // Claude API 해설 텍스트
  drawRound     Int?     // 해당 회차
  isPurchased   Boolean  @default(false)
  isManual      Boolean  @default(false) // 수동 입력 여부
  createdAt     DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  lottoDraw LottoDraw? @relation(fields: [drawRound], references: [round])

  @@index([userId, isManual, createdAt(sort: Desc)])
}

// 로또 당첨 번호 (매주 업데이트)
model LottoDraw {
  id          String   @id @default(cuid())
  round       Int      @unique // 회차
  drawDate    DateTime // 추첨일
  numbers     Int[]    // [1, 7, 14, 22, 35, 40]
  bonus       Int      // 보너스 번호
  prize1st    BigInt?  // 1등 당첨금
  winners1st  Int?     // 1등 당첨자 수
  prize2nd    BigInt?  // 2등 당첨금
  winners2nd  Int?     // 2등 당첨자 수
  prize3rd    Int?     // 3등 1인당 당첨금
  winners3rd  Int?     // 3등 당첨자 수
  prize4th    Int?     // 4등 1인당 당첨금 (고정 50,000)
  winners4th  Int?     // 4등 당첨자 수
  prize5th    Int?     // 5등 1인당 당첨금 (고정 5,000)
  winners5th  Int?     // 5등 당첨자 수
  createdAt   DateTime @default(now())

  lottoNumbers LottoNumber[]
  qrScans      QrScan[]
  winStores    LottoDrawStore[]

  @@index([drawDate])
}

// QR 스캔 이력
model QrScan {
  id             String   @id @default(cuid())
  userId         String
  round          Int
  scannedNumbers Json     // [{set:1, numbers:[1,2,3,4,5,6]}, ...]
  result         Json?    // [{set:1, rank:5, prize:5000}, ...]
  totalPrize     BigInt   @default(0)
  scannedAt      DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lottoDraw LottoDraw @relation(fields: [round], references: [round])

  @@index([userId, scannedAt(sort: Desc)])
}

// 광고 제거 결제
model AdFreePurchase {
  id            String   @id @default(cuid())
  userId        String   @unique
  amount        Int      @default(5000)
  paymentKey    String?  // 토스페이먼츠 결제키
  paymentMethod String?  // card / kakaopay 등
  status        String   @default("DONE") // DONE / CANCEL / FAIL
  purchasedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 회차별 1등 당첨 판매점
model LottoDrawStore {
  id      String @id @default(cuid())
  round   Int
  name    String
  address String
  method  String?  // 자동/수동

  lottoDraw LottoDraw @relation(fields: [round], references: [round], onDelete: Cascade)

  @@index([round])
  @@unique([round, name])
}

// 로또 판매점 (2차 업데이트)
model LottoStore {
  id            String   @id @default(cuid())
  name          String   // 상호명
  address       String
  lat           Float?   // 위도
  lng           Float?   // 경도
  phone         String?
  district      String?  // 방위 계산용
  addressNumber Int?     // 번지 수리 계산용
  winCount1st   Int      @default(0) // 1등 배출 횟수
  lastUpdated   DateTime @default(now())

  @@index([winCount1st(sort: Desc)])
}

// 푸시 알람 토큰
model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("android")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
